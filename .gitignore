docs/para-test/
docs/temp/
docs/txt/
docu/

# --- Proyectos de referencia ---
web ejemplos/

# --- Screenshots sueltos en raíz ---
/*.png

# --- IDE ---
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---
*.log
error_log

# --- Temp ---
*.tmp
*.bak
*.swp
