# --- Configuración sensible ---
config/database.php
config/mail.php

# --- Uploads de usuarios ---
uploads/*
!uploads/.gitkeep

# --- Dependencias vendor ---
assets/vendor/*
!assets/vendor/.gitkeep

# --- Herramientas Claude / Agents ---
.agent/
.agents/
.claude/
CLAUDE.md
AGENTS.md
skills-lock.json
.impeccable.md
# --- Playwright / Testing ---
.playwright/
.playwright-cli/
.playwright-mcp/

# --- Node.js ---
node_modules/
package.json
package-lock.json

# --- Documentación auxiliar no versionada ---
